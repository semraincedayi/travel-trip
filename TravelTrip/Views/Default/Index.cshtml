@using TravelTrip.Models.Class
@model List<Blog>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_TestLayout.cshtml";
}


<!--
Author: W3layouts
Author URL: http://w3layouts.com
